# ===========================================
# SOPROFEN Production Query Editor - Backend
# ===========================================
# Copy this file to .env and fill in your values

# Server Configuration
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# SQL Server - Training Environment (TRN)
SQL_SERVER_TRN=sql-trn.soprofen.local
SQL_DATABASE_TRN=Production
SQL_USER=query_editor_svc
SQL_PASSWORD=your_secure_password_here

# SQL Server - Production Environment (PRD)
SQL_SERVER_PRD=sql-prd.soprofen.local
SQL_DATABASE_PRD=Production

# SQL Server Options
SQL_ENCRYPT=false
SQL_TRUST_CERT=true

# GitHub Integration
GITHUB_TOKEN=ghp
GITHUB_REPO=EOSWALD-SOPRO/testquery

# Queries Repository Path
QUERIES_PATH=./repo/sql
GIT_REPO_PATH=./repo
